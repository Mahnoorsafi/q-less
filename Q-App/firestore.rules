rules_version = '2';

// Q-Less Queue Management System — Firestore Security Rules
// Project: queue-management-28198
// Deploy: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Branches (public read, authenticated write) ──────────────────────────
    // Branches + menu + services are restaurant-public info — anyone can read.
    // Only authenticated users (customers or admin) can write.
    match /branches/{branchId} {
      allow read:  if true;
      allow write: if request.auth != null;

      match /menu/{itemId} {
        allow read:  if true;
        allow write: if request.auth != null;
      }

      match /services/{serviceId} {
        allow read:  if true;
        allow write: if request.auth != null;
      }
    }

    // ── Tokens ───────────────────────────────────────────────────────────────
    // Any logged-in user can create and read tokens.
    // Any logged-in user can update tokens (admin calls/serves, customer cancels).
    // Tokens are never hard-deleted.
    match /tokens/{tokenId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── Notifications ────────────────────────────────────────────────────────
    // Users read only their own notifications.
    // Any authenticated user can create notifications (admin broadcasts + delays).
    // Only the owner can mark their notifications as read (update).
    match /notifications/{userId}/messages/{msgId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Users (profile) ──────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}